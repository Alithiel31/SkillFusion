// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  VISITOR
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum Difficulte {
  DEBUTANT
  FACILE
  INTERMEDIAIRE
  DIFFICILE
  EXPERT
}

enum Visibilite {
  BROUILLON
  PUBLIE
  ARCHIVE
}

// ─── Entités principales ──────────────────────────────────

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  nom              String
  prenom           String
  mot_de_passe     String
  url_image_profil String?
  role             Role     @default(VISITOR)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cours_crees   Cours[]          @relation("CourseCreator")
  badges        User_has_Badge[]
  enrollments   User_has_Cours[]
  activations   Cours_active[]
  commentaires  Commentaire[]
  opinions      Opinion[]
  notifications Notification[]
}

model Cours {
  id              Int        @id @default(autoincrement())
  titre           String
  phrase_resume   String?
  url_image_intro String?
  difficulte      Difficulte
  resume          String?
  visibilite      Visibilite @default(BROUILLON)
  createur_id     Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createur     User                           @relation("CourseCreator", fields: [createur_id], references: [id], onDelete: Restrict)
  categories   Cours_has_Categories[]
  outils       Cours_has_Outils[]
  objectifs    Cours_has_Objectif_Pedagogique[]
  contenu      Cour_content[]
  enrollments  User_has_Cours[]
  activations  Cours_active[]
  commentaires Commentaire[]
  opinions     Opinion[]
  notifications Notification[]
}

model Categories {
  id          Int    @id @default(autoincrement())
  nom         String
  description String?

  cours Cours_has_Categories[]
}

model Objectif_Pedagogique {
  id          Int    @id @default(autoincrement())
  titre       String
  description String?

  cours Cours_has_Objectif_Pedagogique[]
}

model Outils {
  id          Int    @id @default(autoincrement())
  nom         String
  description String?

  cours Cours_has_Outils[]
}

model Badge {
  id          Int    @id @default(autoincrement())
  nom         String
  description String?

  users User_has_Badge[]
}

model Cour_content {
  id           Int    @id @default(autoincrement())
  cours_id     Int
  numeros_page Int
  contenu      String

  cours Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)

  @@unique([cours_id, numeros_page])
}

// ─── Tables de liaison ────────────────────────────────────

model User_has_Cours {
  id        Int      @id @default(autoincrement())
  user_id   Int
  cours_id  Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cours Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cours_id])
}

model Cours_active {
  id          Int      @id @default(autoincrement())
  user_id     Int
  cours_id    Int
  est_termine Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cours Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cours_id])
}

model User_has_Badge {
  id        Int      @id @default(autoincrement())
  user_id   Int
  badge_id  Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badge_id], references: [id], onDelete: Cascade)

  @@unique([user_id, badge_id])
}

model Cours_has_Categories {
  id            Int @id @default(autoincrement())
  cours_id      Int
  categories_id Int

  cours     Cours      @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  categorie Categories @relation(fields: [categories_id], references: [id], onDelete: Cascade)

  @@unique([cours_id, categories_id])
}

model Cours_has_Outils {
  id        Int @id @default(autoincrement())
  cours_id  Int
  outils_id Int

  cours  Cours  @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  outils Outils @relation(fields: [outils_id], references: [id], onDelete: Cascade)

  @@unique([cours_id, outils_id])
}

model Cours_has_Objectif_Pedagogique {
  id                      Int @id @default(autoincrement())
  cours_id                Int
  objectif_pedagogique_id Int

  cours    Cours                @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  objectif Objectif_Pedagogique @relation(fields: [objectif_pedagogique_id], references: [id], onDelete: Cascade)

  @@unique([cours_id, objectif_pedagogique_id])

}

// ─── Social ───────────────────────────────────────────────

model Commentaire {
  id          Int      @id @default(autoincrement())
  description String
  cours_id    Int
  id_auteur   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cours  Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  auteur User  @relation(fields: [id_auteur], references: [id], onDelete: Cascade)
}

model Opinion {
  id        Int      @id @default(autoincrement())
  message   String
  note      Int      // valeur attendue : 1 à 5 (étoiles)
  cours_id  Int
  user_id   Int
  createdAt DateTime @default(now())

  cours Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, cours_id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  contenu   String
  cours_id  Int
  user_id   Int
  createdAt DateTime @default(now())

  cours Cours @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

